{
  "name": "ferment_scaling",
  "group": "cards",
  "description": "Ferment accrues on Carapace and is kept when played: held 2 turns it grants 6 + 6*2 = 18 Block",
  "setup": {
    "character": "Alchemist",
    "seed": "FERM1",
    "fight": "SLIMES_WEAK"
  },
  "checks": [
    {
      "do": {
        "console": "card ALCHEMIST-CARAPACE"
      },
      "expect": {
        "hand_contains": "Carapace"
      },
      "timeout": 6
    },
    {
      "do": {
        "console": "block 40 0"
      },
      "expect": {
        "block": 40
      },
      "timeout": 6,
      "note": "absorbs the enemy turn, and doubles as the turn barrier below"
    },
    {
      "do": {
        "end_turn": true
      },
      "expect": {
        "block": 0
      },
      "timeout": 8,
      "note": "block only clears at the start of your next turn, so this waits out a real turn; ferment 1"
    },
    {
      "do": {
        "console": "block 40 0"
      },
      "expect": {
        "block": 40
      },
      "timeout": 6
    },
    {
      "do": {
        "end_turn": true
      },
      "expect": {
        "block": 0
      },
      "timeout": 8,
      "note": "ferment 2"
    },
    {
      "do": {
        "play_card": "Carapace"
      },
      "expect": {
        "block": 18
      },
      "timeout": 6,
      "note": "6 base + 6 per turn fermented * 2 = 18 Block"
    }
  ]
}
