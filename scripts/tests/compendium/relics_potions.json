{
  "name": "compendium_relics_potions",
  "group": "compendium",
  "description": "AlchemistRelicPool has all 9 relics and AlchemistPotionPool all 3 potions, by name",
  "checks": [
    {
      "expect": {
        "pool_contains": {
          "pool": "AlchemistRelicPool",
          "names": [
            "WeatheredKit",
            "GildedKit",
            "AquaVitae",
            "AuricSeal",
            "EverflowingChalice",
            "FluxStone",
            "MidasFruit",
            "SnakeTail",
            "ToxicShard"
          ]
        },
        "pool_count": {
          "pool": "AlchemistRelicPool",
          "count": 9
        }
      },
      "timeout": 10
    },
    {
      "expect": {
        "pool_contains": {
          "pool": "AlchemistPotionPool",
          "names": [
            "GoldLeaf",
            "MarshTonic",
            "RefinedExtract"
          ]
        },
        "pool_count": {
          "pool": "AlchemistPotionPool",
          "count": 3
        }
      },
      "timeout": 10
    }
  ]
}