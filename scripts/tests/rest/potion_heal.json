{
  "name": "potion_heal",
  "group": "rest",
  "description": "The starter relic (WeatheredKit) heals 3 HP whenever a potion is used: damaged to 49, drinking a potion returns HP by >= 3",
  "setup": {"character": "Alchemist", "seed": "HEAL1", "fight": "SLIMES_WEAK"},
  "checks": [
    {"do": {"console": "potion ALCHEMIST-MARSH_TONIC"}, "expect": {"potion_count": 1}, "timeout": 6},
    {"do": {"console": "damage 20 0"}, "delay": 0.5},
    {"do": {"snapshot": "hp"}},
    {"do": {"use_potion_ui": 0}, "expect": {"hp_gain_gte": 3, "potion_count": 0}, "timeout": 8, "note": "WeatheredKit heals 3 on potion use"}
  ]
}
