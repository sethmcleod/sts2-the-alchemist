{
  "name": "epoch_reveal_ui",
  "group": "settings",
  "description": "Reveal epochs through the real Timeline UI instead of a direct save write: clicking an obtained tile must run the epoch's QueueUnlocks, draw its expansion children exactly once (AddEpochSlots has no dedup), and unlock that chapter's content. Complements epoch_progression, which drives the same progression through save state and so never reaches the reveal UI at all.",
  "checks": [
    {"do": {"click": "/root/Game/RootSceneContainer/MainMenu/MainMenuTextButtons/ModConfigButton"}, "delay": 1.5, "expect": {"screen_contains": "ModConfig"}, "timeout": 8},
    {"do": {"find_click": {"pattern": "ModButton_The Alchemist", "contains": "ModListContent"}}, "delay": 1.5},
    {"do": {"find_click": {"pattern": "ResetUnlocks", "contains": "SectionContent_Unlocks", "child_class": "Control"}}, "expect": {"game_log_contains": "Re-locked", "exceptions_clean": true}, "timeout": 8, "note": "clean slate: strips discovered + removes the Alchemist epoch entries"},
    {"do": {"click": "/root/Game/ModalContainer/ErrorPopup/VerticalPopup/YesButton"}, "delay": 1},

    {"do": {"bridge": "set_epoch", "params": {"id": "ALCHEMIST-ALCHEMIST1_EPOCH", "state": "Obtained"}}, "expect": {"epoch_state": {
      "epochs": {"ALCHEMIST-ALCHEMIST1_EPOCH": {"state": "Obtained", "visible": true, "revealed": false}}
    }}, "timeout": 6, "note": "Obtained is the click-to-reveal state; set it before the screen opens so InitScreen draws the tile"},

    {"do": {"menu": "back"}, "delay": 1},
    {"do": {"menu": "timeline"}, "delay": 2.5, "expect": {"screen": "TIMELINE"}, "timeout": 10},

    {"expect": {"epoch_state": {
      "epochs": {"ALCHEMIST-ALCHEMIST1_EPOCH": {"slot_count": 1, "slot_state": "Obtained"}}
    }}, "timeout": 10, "note": "exactly one clickable tile for chapter 1 before any reveal"},

    {"do": {"reveal_timeline": {"id": "ALCHEMIST-ALCHEMIST1_EPOCH"}}, "expect": {"epoch_state": {
      "epochs": {
        "ALCHEMIST-ALCHEMIST1_EPOCH": {"revealed": true, "slot_count": 1},
        "ALCHEMIST-ALCHEMIST2_EPOCH": {"visible": true, "revealed": false, "slot_count": 1},
        "ALCHEMIST-ALCHEMIST3_EPOCH": {"slot_count": 1},
        "ALCHEMIST-ALCHEMIST4_EPOCH": {"slot_count": 1},
        "ALCHEMIST-ALCHEMIST5_EPOCH": {"slot_count": 1},
        "ALCHEMIST-ALCHEMIST6_EPOCH": {"slot_count": 1},
        "ALCHEMIST-ALCHEMIST7_EPOCH": {"visible": true, "revealed": false, "slot_count": 1}
      }
    }}, "timeout": 20, "note": "the real reveal path: QueueUnlocks queues the expansion, AddEpochSlots draws 2-7. slot_count 1 everywhere is the duplicate-tile regression"},

    {"expect": {"exceptions_clean": true}, "timeout": 6, "note": "the reveal animation and unlock screens must not throw"},

    {"do": {"menu": "back"}, "delay": 1.5},
    {"do": {"bridge": "set_epoch", "params": {"id": "ALCHEMIST-ALCHEMIST2_EPOCH", "state": "Obtained"}}, "delay": 0.5, "note": "chapter 2 is NotObtained after the expansion; earn it so its tile becomes clickable"},
    {"do": {"menu": "timeline"}, "delay": 2.5, "expect": {"screen": "TIMELINE"}, "timeout": 10},

    {"do": {"reveal_timeline": {"id": "ALCHEMIST-ALCHEMIST2_EPOCH"}}, "expect": {"epoch_state": {
      "epochs": {
        "ALCHEMIST-ALCHEMIST2_EPOCH": {"revealed": true, "slot_count": 1},
        "ALCHEMIST-ALCHEMIST1_EPOCH": {"slot_count": 1}
      },
      "cards": {
        "CARD.ALCHEMIST-CONGEAL": {"unlocked": true},
        "CARD.ALCHEMIST-CORRODE": {"unlocked": true},
        "CARD.ALCHEMIST-SWEAT_IT_OUT": {"unlocked": true},
        "CARD.ALCHEMIST-CARAPACE": {"unlocked": false}
      }
    }}, "timeout": 20, "note": "content gating works through the real path too: chapter 2 unlocks its 3 cards, chapter 5's stay locked"},

    {"do": {"menu": "back"}, "delay": 1.5},
    {"do": {"click": "/root/Game/RootSceneContainer/MainMenu/MainMenuTextButtons/ModConfigButton"}, "delay": 1.5, "expect": {"screen_contains": "ModConfig"}, "timeout": 8},
    {"do": {"find_click": {"pattern": "ModButton_The Alchemist", "contains": "ModListContent"}}, "delay": 1.5},
    {"do": {"find_click": {"pattern": "ResetUnlocks", "contains": "SectionContent_Unlocks", "child_class": "Control"}}, "expect": {"game_log_contains": "Re-locked"}, "timeout": 8, "note": "cleanup: re-lock everything"},
    {"do": {"click": "/root/Game/ModalContainer/ErrorPopup/VerticalPopup/YesButton"}, "delay": 1},
    {"do": {"bridge": "set_epoch", "params": {"id": "ALCHEMIST-ALCHEMIST1_EPOCH", "state": "NotObtained"}}, "expect": {"epoch_state": {
      "epochs": {"ALCHEMIST-ALCHEMIST1_EPOCH": {"visible": true, "revealed": false}, "ALCHEMIST-ALCHEMIST2_EPOCH": {"visible": false}},
      "cards": {"CARD.ALCHEMIST-CONGEAL": {"unlocked": false}}
    }}, "timeout": 6, "note": "leave the profile back in the fresh-timeline state"}
  ]
}
