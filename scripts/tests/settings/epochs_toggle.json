{
  "name": "epochs_toggle",
  "group": "settings",
  "description": "Enable Epochs toggle: flipping it off hides the Alchemist epochs and the Timeline still opens cleanly (exercises the AddEpochSlots hide patch), then flipping it back on restores without exceptions",
  "checks": [
    {"do": {"click": "/root/Game/RootSceneContainer/MainMenu/MainMenuTextButtons/ModConfigButton"}, "delay": 1.5, "expect": {"screen_contains": "ModConfig"}, "timeout": 8},
    {"do": {"find_click": {"pattern": "ModButton_The Alchemist", "contains": "ModListContent"}}, "delay": 1.5},
    {"do": {"find_click": {"pattern": "EnableEpochs", "contains": "SectionContent_Timeline", "child_class": "Control"}}, "delay": 1, "note": "toggle epochs OFF"},
    {"do": {"menu": "back"}, "delay": 1},
    {"do": {"menu": "timeline"}, "delay": 2, "expect": {"exceptions_clean": true}, "timeout": 8, "note": "Timeline opens with epochs disabled; the hide patch strips our slots without error"},
    {"do": {"menu": "back"}, "delay": 1},
    {"do": {"click": "/root/Game/RootSceneContainer/MainMenu/MainMenuTextButtons/ModConfigButton"}, "delay": 1.5, "expect": {"screen_contains": "ModConfig"}, "timeout": 8},
    {"do": {"find_click": {"pattern": "ModButton_The Alchemist", "contains": "ModListContent"}}, "delay": 1.5},
    {"do": {"find_click": {"pattern": "EnableEpochs", "contains": "SectionContent_Timeline", "child_class": "Control"}}, "delay": 1, "expect": {"exceptions_clean": true}, "timeout": 5, "note": "toggle epochs back ON (restore)"}
  ]
}
