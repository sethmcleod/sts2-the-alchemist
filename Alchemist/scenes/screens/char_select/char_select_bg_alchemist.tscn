[gd_scene load_steps=8 format=3]

; Placeholder Alchemist character-select splash. An animated gradient in the style of
; the base game's Random splash (char_select_bg_random_character.tscn): a multi-stop
; gradient with slow two-tone swirls, pulsing lights, and rising bubble specks.
;
; The screen adds this scene under its "AnimatedBg" container, which is deliberately
; larger than the viewport (it is grown by -388/-80 on the top-left and +252/+40 on the
; bottom-right so the base game's oversized parallax art bleeds off every edge). The
; root below cancels exactly those offsets, so it lands on the visible 1920x1080 rect.
;
; The particle textures are base-game resources. A base-game reference bakes to null
; in a mod scene, so CharSelectBgPatches loads them at runtime after the screen
; instantiates this scene. The swirl shader is a mod resource, so the scene references
; it directly. Replace this whole scene with the final animated splash art.

[ext_resource type="Shader" path="res://Alchemist/shaders/char_select_swirl.gdshader" id="swirl_shader"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_swirl"]
shader = ExtResource("swirl_shader")

[sub_resource type="Gradient" id="Gradient_alch"]
interpolation_mode = 2
offsets = PackedFloat32Array(0, 0.2, 0.42, 0.62, 0.84, 1)
